{
  "name": "helpdesk-ia-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "pretest": "npm run db:migrate",
    "test": "vitest run --no-file-parallelism",
    "db:migrate": "prisma generate && node --no-warnings prisma/migrate.js",
    "db:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "6.11.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.0",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "helpdesk-ia": "file:..",
    "zod": "^3.25.74"
  },
  "devDependencies": {
    "prisma": "6.11.1",
    "supertest": "^7.1.1",
    "vitest": "^3.2.4"
  }
}
